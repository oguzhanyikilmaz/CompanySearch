{
  "SeedDemoData": true,
  "Persistence": {
    "UseSqliteForLocalDevelopment": true
  },
  "Caching": {
    "UseInMemoryCache": true
  },
  "Jobs": {
    "UseInlineScheduler": true
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=companysearch-dev.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    }
  }
}
